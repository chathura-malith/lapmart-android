<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item
                android:left="4dp"
                android:right="4dp"
                android:top="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/md_theme_onBackground_highContrast" /> <corners android:radius="20dp" /> </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>